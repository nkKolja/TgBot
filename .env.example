# Telegram bot token (required)
TELEGRAM_BOT_TOKEN=

# ffmpeg/ffprobe/yt-dlp paths (auto-detected from PATH if not set)
# YTDLP_BIN=/opt/homebrew/bin/yt-dlp
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# FFPROBE_BIN=/opt/homebrew/bin/ffprobe

# Service credentials (optional, <SERVICE>_USERNAME / <SERVICE>_PASSWORD)
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

TWITTER_USERNAME=
TWITTER_PASSWORD=

TIKTOK_USERNAME=
TIKTOK_PASSWORD=

REDDIT_USERNAME=
REDDIT_PASSWORD=

LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# Download timeout in seconds (default: 30)
# DOWNLOAD_TIMEOUT_SECS=30

# Videos longer than this (in seconds) trigger an audio/video prompt (default: 300 = 5 min)
# LONG_VIDEO_SECS=300

# Log level (optional, default: info)
# RUST_LOG=tgbot=info
